{
  "name": "flight-finder-backend",
  "version": "0.1.0",
  "description": "Flight finder backend API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
