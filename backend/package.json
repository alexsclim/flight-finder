    "axios": "^1.6.0",
    "bullmq": "^4.10.0",
    "redis": "^4.6.0",
    "twilio": "^3.85.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/bcrypt": "^5.0.1",
    "typescript": "^5.2.0",
    "tsx": "^4.0.0",
    "prisma": "^5.7.0"
  }
