// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  phoneNumber       String?
  notificationsEnabled Boolean @default(true)
  alertCooldownMinutes Int @default(30)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  alerts            Alert[]
  searchSessions    SearchSession[]
  alertMatches      AlertMatch[]
}

model Alert {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  departureAirport  String    // IATA code
  arrivalAirport    String    // IATA code
  startDate         DateTime
  endDate           DateTime
  cabinClasses      String[]  // ["Economy", "Business", "First"]
  airlines          String[]  // ["United", "Alaska", "Flying Blue"]
  maxMilesCost      Int?      // null = no limit
  
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastChecked       DateTime?
  
  matches           AlertMatch[]
}

model AlertMatch {
  id                String    @id @default(cuid())
  alertId           String
  alert             Alert     @relation(fields: [alertId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  airline           String
  departureDate     DateTime
  cabinClass        String
  milesCost         Int
  availableSeat     Boolean   @default(true)
  
  notificationSent  Boolean   @default(false)
  notificationTime  DateTime?
  
  createdAt         DateTime  @default(now())
  
  @@index([alertId])
  @@index([userId])
}

model SearchSession {
  id                String    @id @default(cuid())
  userId            String?
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  departureAirport  String
  arrivalAirport    String
  startDate         DateTime
  endDate           DateTime
  cabinClasses      String[]
  airlines          String[]
  maxMilesCost      Int?
  
  results           AvailabilityResult[]
  
  createdAt         DateTime  @default(now())
  expiresAt         DateTime  @default(dbgenerated("now() + interval '30 minutes'"))
  
  @@index([userId])
  @@index([expiresAt])
}

model AvailabilityResult {
  id                String    @id @default(cuid())
  searchSessionId   String
  searchSession     SearchSession @relation(fields: [searchSessionId], references: [id], onDelete: Cascade)
  
  airline           String
  departureDate     DateTime
  departureTime     String?   // HH:mm format
  arrivalTime       String?   // HH:mm format
  cabinClass        String
  milesCost         Int
  availableSeats    Int       // -1 = unknown, 0 = not available, >0 = available
  externalId        String?   // ID from airline system
  
  createdAt         DateTime  @default(now())
  
  @@index([searchSessionId])
  @@index([airline, departureDate])
}

model AirlineAPIKey {
  id                String    @id @default(cuid())
  airline           String    @unique
  apiKey            String
  apiBase           String?
  creditsRemaining  Int?
  rateLimit         String?   // e.g., "500/hour"
  lastUpdated       DateTime  @default(now())
}
